{
  "name": "pbleap",
  "version": "1.2.0",
  "publisher": "heyzec",
  "license": "MIT",
  "displayName": "PBLeap",
  "description": " Quickly navigate from protobuf files to generated code",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heyzec/pbleap.git"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "client/assets/icon.png",
  "engines": {
    "vscode": "^1.93.0"
  },
  "main": "./client/dist/wrapper.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "PBLeap Configuration",
      "properties": {
        "pbleap.protoGenMapping": {
          "type": "object",
          "description": "Map of protobuf paths to generated file paths.",
          "default": {},
          "additionalProperties": {
            "type": [
              "string"
            ]
          }
        }
      }
    }
  },
  "scripts-info": {
    "build": "Creates all files required for the extension",
    "format": "Format source code",
    "watch": "Rebuild source code in this repo on change",
    "vscode:prepublish": "Step called by vsce before packaging/publishing (convention by VS Code)",
    "package": "Package the extension into .vsix format"
  },
  "scripts": {
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "build:shim": "cd shim && npm run build",
    "build": "npm run build:client && npm run build:server && npm run build:shim",
    "format": "prettier . --write",
    "watch": "npm run build:client -- --watch & npm run build:server -- --watch",
    "vscode:prepublish": "npm run build",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "@vscode/vsce": "^3.7.0",
    "esbuild": "^0.28.1",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "typescript": "^5.6.2"
  }
}
